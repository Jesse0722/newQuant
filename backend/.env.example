# Tushare Pro API Token (必填，在 https://tushare.pro 获取)
TUSHARE_TOKEN=your_tushare_token_here
# Tushare 代理地址 (留空则使用官方接口)
TUSHARE_API_URL=
# SQLite 数据库路径 (相对于 backend/ 目录)
DATABASE_URL=sqlite:///./data/quant.db
# 数据目录 (相对于 backend/ 目录)
DATA_DIR=./data

# AI 智能选股（可选）
# AI_PROVIDER=openai|qwen|ollama
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini
# DASHSCOPE_API_KEY=
# DASHSCOPE_MODEL=qwen-plus
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=qwen2.5:7b
